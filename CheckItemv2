-- BF Quick Account Check v10
local plr = game.Players.LocalPlayer
local CommF = game:GetService("ReplicatedStorage").Remotes.CommF_
local CoreGui = game:GetService("CoreGui")
if CoreGui:FindFirstChild("BFCheck") then CoreGui.BFCheck:Destroy() end

-- ===== TARGET LIST =====
local TARGET_FRUITS = {
    {"Dragon", "dragon"}, {"Kitsune", "kitsune"}, {"Tiger", "tiger"},
    {"Spirit", "spirit"}, {"Control", "control"}, {"Venom", "venom"},
    {"Shadow", "shadow"}, {"Dough", "dough"}, {"T-Rex", "t-rex"},
    {"Mammoth", "mammoth"}, {"Gravity", "gravity"},
}
local TARGET_SWORDS = {"Shark Anchor", "Cursed Dual Katana"}
local TARGET_GUNS   = {"Skull Guitar"}
local TARGET_ITEMS  = {{"Mirror Fractal", "Mirror Fractal"}, {"Mảnh mũ Valkyrie", "Valkyrie"}}

local MYTHIC_GROUPS = {
    {"dragon"}, {"kitsune"}, {"tiger","leopard"}, {"spirit","soul"},
    {"control"}, {"venom"}, {"shadow"}, {"dough","mochi"},
    {"t-rex"}, {"mammoth"}, {"gravity"}, {"portal"}, {"yeti"},
}

local PREREQS = {"Black Leg", "Electro", "Fishman Karate", "Dragon Claw",
                 "Superhuman", "Death Step", "Sharkman Karate",
                 "Electric Claw", "Dragon Talon"}
local PREREQ_REMOTE = {
    ["Black Leg"]="BuyBlackLeg", ["Electro"]="BuyElectro",
    ["Fishman Karate"]="BuyFishmanKarate", ["Dragon Claw"]="BuyDragonClaw",
    ["Superhuman"]="BuySuperhuman", ["Death Step"]="BuyDeathStep",
    ["Sharkman Karate"]="BuySharkmanKarate", ["Electric Claw"]="BuyElectricClaw",
    ["Dragon Talon"]="BuyDragonTalon",
}
local TOTAL_MELEES = 12
local SWORD_ABBR = {
    ["Cursed Dual Katana"] = "cdk",
    ["Shark Anchor"] = "sa",
}

-- ===== FETCH =====
local inv = CommF:InvokeServer("getInventory") or {}
local fruitsBox = CommF:InvokeServer("getInventoryFruits") or {}
local D = plr:FindFirstChild("Data")
local char = plr.Character

local ownedFruits = {}
local currentFruit = (D and D:FindFirstChild("DevilFruit")) and D.DevilFruit.Value or ""
if currentFruit ~= "" then ownedFruits[currentFruit:lower()] = true end
for _, f in pairs(fruitsBox) do
    if type(f) == "table" and f.Name then ownedFruits[f.Name:lower()] = true end
end
for _, item in pairs(inv) do
    if type(item) == "table" and item.Type == "Blox Fruit" and item.Name then
        ownedFruits[item.Name:lower()] = true
    end
end
for _, p in ipairs({plr.Backpack, char}) do
    if p then
        for _, t in pairs(p:GetChildren()) do
            if t:IsA("Tool") and (t.ToolTip == "Blox Fruit" or t:FindFirstChild("EatRemote")) then
                ownedFruits[t.Name:lower()] = true
                local on = t:GetAttribute("OriginalName")
                if on then ownedFruits[on:lower()] = true end
            end
        end
    end
end

local function hasFruit(key)
    local k = key:lower()
    for owned in pairs(ownedFruits) do
        if owned:find(k, 1, true) then return true end
    end
    return false
end

local function hasInvItem(target)
    local k = target:lower()
    for _, item in pairs(inv) do
        if type(item) == "table" and item.Name and item.Name:lower():find(k, 1, true) then
            return true
        end
    end
    return false
end

local function countMythics()
    local cnt = 0
    for _, group in ipairs(MYTHIC_GROUPS) do
        for _, k in ipairs(group) do
            if hasFruit(k) then cnt = cnt + 1; break end
        end
    end
    return cnt
end
local mythicCount = countMythics()

local function getMochiTier()
    local doughTool
    for _, p in ipairs({plr.Backpack, char}) do
        if p then
            for _, t in pairs(p:GetChildren()) do
                if t:IsA("Tool") and (t.Name:lower():find("dough") or t.Name:lower():find("mochi")) then
                    doughTool = t; break
                end
            end
        end
    end
    if not doughTool then return "v1" end
    local aw = doughTool:FindFirstChild("AwakenedMoves")
    if not aw then return "v1" end
    local cnt = 0
    for _, k in ipairs({"Z","X","C","V","F"}) do
        if aw:FindFirstChild(k) then cnt = cnt + 1 end
    end
    return cnt >= 5 and "v2" or "v1"
end

local function getDfLabel()
    if currentFruit == "" then
        return mythicCount > 0 and (mythicCount .. " mithic") or "không ăn"
    end
    local cf = currentFruit:lower()
    if cf:find("dough") or cf:find("mochi") then return "mochi " .. getMochiTier()
    elseif cf:find("kitsune") then return "df kit"
    elseif cf:find("tiger") or cf:find("leopard") then return "df tiger"
    else return mythicCount .. " mithic" end
end

local tier = "V1"
local v4Sub = nil
if char and char:FindFirstChild("RaceTransformed") then
    tier = "V4"
    if D and D:FindFirstChild("Race") and D.Race:FindFirstChild("C") then
        v4Sub = D.Race.C.Value
    end
else
    local ok3, r3 = pcall(function() return CommF:InvokeServer("Wenlocktoad", "1") end)
    local ok2, r2 = pcall(function() return CommF:InvokeServer("Alchemist", "1") end)
    if ok3 and r3 == -2 then tier = "V3"
    elseif ok2 and r2 == -2 then tier = "V2" end
end

local race = (D and D:FindFirstChild("Race")) and D.Race.Value or "?"
local lvl  = (D and D:FindFirstChild("Level")) and D.Level.Value or "?"
local beli = (D and D:FindFirstChild("Beli")) and D.Beli.Value or "?"
local frag = (D and D:FindFirstChild("Fragments")) and D.Fragments.Value or "?"

local bounty = "?"
local ls = plr:FindFirstChild("leaderstats")
if ls and ls:FindFirstChild("Bounty/Honor") then
    bounty = ls["Bounty/Honor"].Value
elseif ls and ls:FindFirstChild("Bounty") then
    bounty = ls.Bounty.Value
end

-- ===== MELEE =====
local function isOwned(remoteName)
    local ok, ret = pcall(function() return CommF:InvokeServer(remoteName, true) end)
    if not ok then return false end
    return ret ~= nil and type(ret) ~= "string"
end

local meleeData = {}
for _, p in ipairs({plr.Backpack, char}) do
    if p then
        for _, t in pairs(p:GetChildren()) do
            if t:IsA("Tool") and t.ToolTip == "Melee" then
                local l = t:FindFirstChild("Level")
                meleeData[t.Name] = {mastery = l and l.Value or 0, equipped = (p == char)}
            end
        end
    end
end

local ownedMelee = {}
local missingMelees = {}
local function addMelee(name)
    local md = meleeData[name]
    table.insert(ownedMelee, {
        name = name,
        mastery = md and md.mastery or nil,
        equipped = md and md.equipped or false,
    })
end

addMelee("Combat")
local hasGodhuman = isOwned("BuyGodhuman")
if hasGodhuman then
    for _, m in ipairs(PREREQS) do addMelee(m) end
    addMelee("Godhuman")
else
    for _, m in ipairs(PREREQS) do
        if isOwned(PREREQ_REMOTE[m]) then addMelee(m)
        else table.insert(missingMelees, m) end
    end
    table.insert(missingMelees, "Godhuman")
end
if isOwned("BuySanguineArt") or meleeData["Sanguine Art"] then
    addMelee("Sanguine Art")
else
    table.insert(missingMelees, "Sanguine Art")
end

table.sort(ownedMelee, function(a, b)
    if a.equipped ~= b.equipped then return a.equipped end
    local am = type(a.mastery) == "number" and a.mastery or -1
    local bm = type(b.mastery) == "number" and b.mastery or -1
    return am > bm
end)

