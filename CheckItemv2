-- ===== WORKSPACE FILE =====
local function buildCompleted()
    local parts = {"Completed-LV" .. tostring(lvl)}

    local hasGod, hasSang = false, false
    for _, m in ipairs(ownedMelee) do
        if m.name == "Godhuman" then hasGod = true end
        if m.name == "Sanguine Art" then hasSang = true end
    end
    if hasGod and hasSang then table.insert(parts, "godmelenew")
    elseif hasGod then table.insert(parts, "god")
    elseif hasSang then table.insert(parts, "san") end

    local swords = {}
    for orig, abbr in pairs(SWORD_ABBR) do
        if hasInvItem(orig) then table.insert(swords, abbr) end
    end
    if #swords > 0 then table.insert(parts, table.concat(swords, " ")) end

    if hasInvItem("Skull Guitar") then table.insert(parts, "sgt") end

    local hasMF = hasInvItem("Mirror Fractal")
    local hasVK = hasInvItem("Valkyrie")
    if hasMF and hasVK then table.insert(parts, "mm")
    elseif hasMF then table.insert(parts, "mf")
    elseif hasVK then table.insert(parts, "vk") end

    -- DF đang ăn
    if currentFruit ~= "" then
        local cf = currentFruit:lower()
        local label
        if cf:find("dough") or cf:find("mochi") then label = "Mc" .. getMochiTier()
        elseif cf:find("tiger") or cf:find("leopard") then label = "tiger"
        elseif cf:find("kitsune") then label = "kit"
        else label = "mithic" end
        table.insert(parts, label)
    end

    -- Race: CHỈ ghi khi V4
    if tier == "V4" then
        local raceStr = race .. " V4"
        if v4Sub then raceStr = raceStr .. " T" .. tostring(v4Sub) end
        table.insert(parts, raceStr)
    end

    -- FRUITS
    local hasT, hasK, hasD, mc = false, false, false, 0
    for name in pairs(ownedFruits) do
        if name == currentFruit:lower() then
            -- skip fruit đang ăn
        elseif name:find("tiger") or name:find("leopard") then hasT = true
        elseif name:find("kitsune") then hasK = true
        elseif name:find("dough") or name:find("mochi") then hasD = true
        else
            local isMythic = false
            for _, group in ipairs(MYTHIC_GROUPS) do
                for _, k in ipairs(group) do
                    if name:find(k) then isMythic = true; break end
                end
                if isMythic then break end
            end
            if isMythic then mc = mc + 1 end
        end
    end

    local fruitsList = {}
    if hasT then table.insert(fruitsList, "tiger") end
    if hasK then table.insert(fruitsList, "kit") end
    if hasD then table.insert(fruitsList, "dough") end
    if mc > 0 then table.insert(fruitsList, mc .. "mithic") end
    if #fruitsList > 0 then
        table.insert(parts, table.concat(fruitsList, "+"))
    end

    return table.concat(parts, ",")
end

local completedText = buildCompleted()
print(output)
